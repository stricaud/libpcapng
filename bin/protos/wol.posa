# Wake-on-LAN magic packet — 102 bytes
# 6 bytes of 0xFF followed by the target MAC address repeated 16 times.
# Typically sent as UDP broadcast to port 9 (or 7), or as a raw Ethernet frame.
# Set sync to ff:ff:ff:ff:ff:ff and target to 16 repetitions of the MAC to wake.
Object<main> WOL
    required bytes<6>  sync
    required bytes<96> target
